# ============================================================
#  OMNIX — AI Personal Companion (Web App)
#  Optional: Google Gemini API for enhanced AI responses
# ============================================================

# ── Google Gemini AI (OPTIONAL - FREE) ──────────────────
# Get yours at: https://aistudio.google.com/app/apikey
# Free limits: 15 requests/min, 1 million tokens/day
# Note: OMNIX works without this key using built-in AI
GEMINI_API_KEY=your_gemini_api_key_here

# ── Cloud Sync (OPTIONAL) ───────────────────────────────
# For multi-device sync (Supabase or Firebase)
# Leave empty for local-only storage
CLOUD_PROVIDER=local
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here
FIREBASE_URL=your_firebase_url_here

# ── App Configuration ───────────────────────────────────
APP_NAME=OMNIX
DEFAULT_LANGUAGE=en-US
DEFAULT_THEME=dark
